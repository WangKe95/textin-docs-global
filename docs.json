{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TextIn Intelligent Document Parsing",
  "colors": {
    "primary": "#1a66ff",
    "light": "#1a66ff",
    "dark": "#1a66ff"
  },
  "favicon": "/favicon.png",
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "xparse/overview",
              "xparse/authentication",
              "xparse/supported-files"
            ]
          },
          {
            "group": "Parse",
            "pages": [
              "xparse/parse/quickstart",
              "xparse/parse/configuration",
              "xparse/parse/response-format",
              "xparse/parse/async-processing",
              "xparse/parse/examples"
            ]
          },
          {
            "group": "Extract",
            "pages": [
              "xparse/extract/quickstart",
              "xparse/extract/schema-guide",
              "xparse/extract/response-format",
              "xparse/extract/best-practices"
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Parse API",
            "pages": [
              "api-reference/endpoint/xparse/v1/parse-sync",
              "api-reference/endpoint/xparse/v1/parse-async",
              "api-reference/endpoint/xparse/v1/parse-async-status"
            ]
          },
          {
            "group": "Extract API",
            "pages": [
              "api-reference/endpoint/extract-v3"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "icon": "github",
        "href": "https://github.com/intsig-textin"
      },
      {
        "label": "Support",
        "href": "https://www.textin.ai/en/contact"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try It Now",
      "href": "https://www.textin.ai/console/recognition/robot_markdown_beta?service=pdf_to_markdown"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/intsig-textin"
    }
  },
  "api": {
    "playground": {
      "proxy": false,
      "display": "simple"
    }
  }
}
