{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "TextIn Intelligent Document Parsing",
  "colors": {
    "primary": "#1a66ff",
    "light": "#1a66ff",
    "dark": "#1a66ff"
  },
  "favicon": "/favicon.png",
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "xparse/overview",
              "xparse/authentication"
            ]
          },
          {
            "group": "Parsing",
            "pages": [
              "xparse/v1/quickstart",
              "xparse/v1/parse-config",
              "xparse/v1/parse-response"
            ]
          },
          {
            "group": "Extraction",
            "pages": [
              "xparse/extract-quickstart-v3",
              "xparse/extract-tutorial-v3",
              "xparse/extract-best-practices-v3",
              {
                "group": "Quick Debug",
                "pages": [
                  "xparse/extract-debug-postman",
                  "xparse/extract-debug-apifox"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "API",
        "groups": [
          {
            "group": "Document Parsing API",
            "pages": [
              "api-reference/endpoint/xparse/v1/parse-sync",
              "api-reference/endpoint/xparse/v1/parse-async",
              "api-reference/endpoint/xparse/v1/parse-async-status"
            ]
          },
          {
            "group": "Document Extraction API",
            "pages": [
              "api-reference/endpoint/extract-v3"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "icon": "github",
        "href": "https://github.com/intsig-textin"
      },
      {
        "label": "News",
        "href": "https://www.textin.ai/news/list"
      },
      {
        "label": "Support",
        "href": "https://www.textin.ai/document/list"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try It Now",
      "href": "https://www.textin.ai/console/recognition/robot_markdown_beta?service=pdf_to_markdown"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/intsig-textin"
    }
  },
  "api": {
    "playground": {
      "proxy": false,
      "display": "simple"
    }
  }
}
